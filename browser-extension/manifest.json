{
  "manifest_version": 3,
  "name": "Sentinel AI Assistant",
  "version": "1.1.0",
  "description": "AI-powered assistant for the Sentinel AI PAC 'Red Portal' and bias detection.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "contextMenus",
    "notifications",
    "clipboardRead",
    "clipboardWrite",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "side_panel/index.html"
  },
  "action": {
    "default_title": "Sentinel AI"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "css": ["content/content-style.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      }
    },
    "export-canvas": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Export current research to Markdown"
    }
  }
}
