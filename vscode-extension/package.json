{
  "name": "meowstik-vscode",
  "displayName": "Meowstik AI Assistant",
  "description": "VS Code extension for Meowstik AI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "meowstik.start",
        "title": "Meowstik: Start Assistant"
      },
      {
        "command": "meowstik.sendSelection",
        "title": "Send to Meowstik"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "meowstik.sendSelection",
          "group": "navigation",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "Meowstik",
      "properties": {
        "meowstik.serverUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "URL of the Meowstik backend server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  }
}
